<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_skeleton_rounded"
    android:padding="14dp">

    <View
        android:id="@+id/skTitle"
        android:layout_width="0dp"
        android:layout_height="18dp"
        android:background="@drawable/bg_skeleton_rounded"
        app:layout_constraintEnd_toStartOf="@id/skThumb"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/skThumb"
        android:layout_width="90dp"
        android:layout_height="70dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_skeleton_rounded"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/skLine2"
        android:layout_width="0dp"
        android:layout_height="14dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_skeleton_rounded"
        app:layout_constraintEnd_toStartOf="@id/skThumb"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skTitle" />

    <View
        android:id="@+id/skLine3"
        android:layout_width="0dp"
        android:layout_height="14dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_skeleton_rounded"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skThumb" />

    <View
        android:id="@+id/skLine4"
        android:layout_width="0dp"
        android:layout_height="14dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_skeleton_rounded"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skLine3" />

    <View
        android:id="@+id/skPrice"
        android:layout_width="140dp"
        android:layout_height="22dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_skeleton_rounded"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skLine4" />

    <View
        android:id="@+id/skButton"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_skeleton_rounded"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skPrice" />

</androidx.constraintlayout.widget.ConstraintLayout>

