<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".view.activity.BookingHistoryDetailActivity"
    android:background="#F5F6F8">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#0B4AA2"
            app:titleTextColor="@android:color/white"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
            app:title="Chi tiết đặt phòng" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="12dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        >
       <LinearLayout
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:orientation="vertical">
           <!-- STATUS -->
           <TextView
               android:id="@+id/txtStatus"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:text="Đặt thành công"
               android:textColor="#2ECC71"
               android:textSize="14sp"
               android:background="@drawable/bg_placeholder"
               android:layout_marginTop="8dp"
               android:layout_marginBottom="8dp"/>

           <!-- HOTEL CARD -->
           <androidx.cardview.widget.CardView
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               app:cardCornerRadius="12dp"
               app:cardElevation="2dp">

               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:orientation="vertical"
                   android:padding="12dp">

                   <TextView
                       android:id="@+id/txtHotelName"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="Tên khách sạn"
                       android:textColor="#2196F3"
                       android:textStyle="bold"
                       android:textSize="16sp"/>
                   <TextView
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="Số đêm"
                       android:layout_marginTop="6dp"/>
                   <TextView
                       android:id="@+id/txtNumberOfNight"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:textStyle="bold"
                       android:text="2 đêm"
                      />
                   <View
                       android:layout_width="match_parent"
                       android:layout_height="1dp"
                       android:background="#EEEEEE"
                       android:layout_marginVertical="10dp"/>
                   <TextView
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="Khách"
                       android:layout_marginTop="4dp"/>
                   <TextView
                       android:id="@+id/txtGuestSummary"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="2 người lớn"
                       android:textStyle="bold"
                    />

               </LinearLayout>
           </androidx.cardview.widget.CardView>

           <!-- BOOKING INFO -->
           <androidx.cardview.widget.CardView
               android:layout_marginTop="10dp"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               app:cardCornerRadius="12dp">

               <LinearLayout
                   android:padding="12dp"
                   android:orientation="vertical"
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content">

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:text="Nhận phòng"
                       />

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:id="@+id/txtCheckin"
                       android:textStyle="bold"
                       android:text="20/12/2026"/>
                   <View
                       android:layout_width="match_parent"
                       android:layout_height="1dp"
                       android:background="#EEEEEE"
                       android:layout_marginVertical="10dp"/>
                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:text="Trả phòng"
                       android:layout_marginTop="8dp"/>

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:id="@+id/txtCheckout"
                       android:textStyle="bold"
                       android:text="25/12/2026"/>

               </LinearLayout>
           </androidx.cardview.widget.CardView>


           <!-- CONTACT INFO -->
           <androidx.cardview.widget.CardView
               android:layout_marginTop="10dp"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               app:cardCornerRadius="12dp">

               <LinearLayout
                   android:padding="12dp"
                   android:orientation="vertical"
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content">


                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:text="Thông tin liên hệ"
                       android:textStyle="bold"/>

                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:gravity="center"
                       android:orientation="horizontal">
                       <TextView
                           android:layout_height="wrap_content"
                           android:layout_width="wrap_content"
                           android:layout_weight="1"
                           android:text="Họ và tên"/>
                       <TextView
                           android:textStyle="bold"
                           android:layout_height="wrap_content"
                           android:layout_width="wrap_content"
                           android:id="@+id/txtContactName"
                           android:text="Nguyen Van A"/>

                   </LinearLayout>

                   <View
                       android:layout_width="match_parent"
                       android:layout_height="1dp"
                       android:background="#EEEEEE"
                       android:layout_marginVertical="10dp"/>
                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:gravity="center"
                       android:orientation="horizontal">
                       <TextView
                           android:layout_height="wrap_content"
                           android:layout_width="wrap_content"
                           android:layout_weight="1"
                           android:text="Số điện thoại"/>
                       <TextView
                           android:layout_height="wrap_content"
                           android:layout_width="wrap_content"
                           android:id="@+id/txtPhone"
                           android:textStyle="bold"
                           android:text="098353553"/>
                   </LinearLayout>
                   <View
                       android:layout_width="match_parent"
                       android:layout_height="1dp"
                       android:background="#EEEEEE"
                       android:layout_marginVertical="10dp"/>

                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:gravity="center"
                       android:orientation="horizontal">
                       <TextView
                           android:layout_height="wrap_content"
                           android:layout_width="wrap_content"
                           android:layout_weight="1"
                           android:text="Email"/>
                       <TextView
                           android:layout_height="wrap_content"
                           android:layout_width="wrap_content"
                           android:id="@+id/txtEmail"
                           android:textStyle="bold"
                           android:text="nguyevana@mail.com"/>
                   </LinearLayout>



               </LinearLayout>
           </androidx.cardview.widget.CardView>

           <!-- PRICE DETAIL -->
           <androidx.cardview.widget.CardView
               android:layout_marginTop="10dp"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               app:cardCornerRadius="12dp">

               <LinearLayout
                   android:padding="12dp"
                   android:orientation="vertical"
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content">

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:text="Chi tiết giá"
                       android:textStyle="bold"/>

                   <!-- RecyclerView: BookedRoom list -->
                   <androidx.recyclerview.widget.RecyclerView
                       android:id="@+id/rvBookedRooms"
                       tools:listitem="@layout/booking_history_detail_item"
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:layout_marginTop="8dp"
                       android:nestedScrollingEnabled="false"/>



                   <!-- Total -->
                   <TextView
                       android:id="@+id/txtTotal"
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:layout_marginTop="8dp"
                       android:textStyle="bold"
                       android:textSize="16sp"
                       android:text="Tổng: --"/>

               </LinearLayout>
           </androidx.cardview.widget.CardView>

       </LinearLayout>





    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>