<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".view.activity.BookingHistoryDetailActivity"
    android:background="#F5F6F8">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#0B4AA2"
            app:titleTextColor="@android:color/white"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
            app:title="Chi tiết đặt phòng" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="12dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        >
       <LinearLayout
           android:layout_width="match_parent"
           android:layout_height="match_parent"
           android:orientation="vertical">
           <!-- STATUS -->
           <TextView
               android:id="@+id/txtStatus"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:text="Đặt thành công"
               android:textColor="#2ECC71"
               android:textSize="14sp"
               android:background="@drawable/bg_placeholder"
               android:layout_marginTop="8dp"
               android:layout_marginBottom="8dp"/>

           <!-- HOTEL CARD -->
           <androidx.cardview.widget.CardView
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               app:cardCornerRadius="12dp"
               app:cardElevation="2dp">

               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:orientation="vertical"
                   android:padding="12dp">

                   <TextView
                       android:id="@+id/txtHotelName"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="Tên khách sạn"
                       android:textColor="#2196F3"
                       android:textStyle="bold"
                       android:textSize="16sp"/>
                   <TextView
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="Số đêm"
                       android:layout_marginTop="6dp"/>
                   <TextView
                       android:id="@+id/txtNumberOfNight"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:textStyle="bold"
                       android:text="2 đêm"
                      />
                   <View
                       android:layout_width="match_parent"
                       android:layout_height="1dp"
                       android:background="#EEEEEE"
                       android:layout_marginVertical="10dp"/>
                   <TextView
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="Khách"
                       android:layout_marginTop="4dp"/>
                   <TextView
                       android:id="@+id/txtGuestSummary"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="2 người lớn"
                       android:textStyle="bold"
                    />

               </LinearLayout>
           </androidx.cardview.widget.CardView>

           <androidx.cardview.widget.CardView
               android:id="@+id/reviewCard"
               android:layout_marginTop="10dp"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               app:cardCornerRadius="12dp">
               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:orientation="vertical"
                   android:padding="12dp">

                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:orientation="horizontal"
                       >
                       <TextView
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:text="Bài đánh giá của bạn"
                           android:layout_weight="1"
                           android:textStyle="bold"/>
                       <ImageView
                           android:id="@+id/menuMore"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:src="@drawable/baseline_more_vert_24"
                           />
                   </LinearLayout>


                   <LinearLayout
                       android:id="@+id/reviewSection"
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:layout_marginTop="12dp"
                       android:orientation="vertical"
                       android:padding="12dp"
                       android:background="@drawable/bg_section_card">

                       <LinearLayout
                           android:layout_width="match_parent"
                           android:layout_height="wrap_content"
                           android:gravity="center_vertical"
                           android:orientation="horizontal">

                           <de.hdodenhof.circleimageview.CircleImageView
                               android:id="@+id/imgReviewerAvatar"
                               android:layout_width="40dp"
                               android:layout_height="40dp"
                               android:src="@drawable/img" />

                           <TextView
                               android:id="@+id/txtReviewerName"
                               android:layout_width="0dp"
                               android:layout_height="wrap_content"
                               android:layout_marginStart="8dp"
                               android:layout_weight="1"
                               android:textColor="#111111"
                               android:textStyle="bold"
                               android:text="my name"/>

                           <TextView
                               android:id="@+id/txtRatingNumber"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:background="@drawable/bg_rating_pill"
                               android:paddingHorizontal="8dp"
                               android:paddingVertical="4dp"
                               android:textColor="@android:color/white"
                               android:textStyle="bold"
                               android:text="9.0"/>

                       </LinearLayout>

                       <LinearLayout
                           android:layout_width="match_parent"
                           android:layout_height="wrap_content"
                           android:layout_marginTop="8dp"
                           android:orientation="horizontal">

                           <TextView
                               android:id="@+id/txtReviewDate"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:textColor="#6D6D6D"
                               android:textSize="12sp"
                               android:text="1/1/2026"/>

                           <TextView
                               android:id="@+id/txtReviewRatingLabel"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:layout_marginStart="8dp"
                               android:textColor="#0B4AA2"
                               android:textSize="12sp"
                               android:textStyle="bold"
                               android:text="Rất tốt"/>

                       </LinearLayout>

                       <TextView
                           android:id="@+id/txtReviewComment"
                           android:layout_width="match_parent"
                           android:layout_height="wrap_content"
                           android:layout_marginTop="8dp"
                           android:textColor="#3D3D3D"
                           android:textSize="13sp"
                           android:text="nhận xét khách sạn"/>


                   </LinearLayout>

                   <TextView
                       android:id="@+id/txtToDoRating"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="Viết bài đánh giá của bạn"
                       android:textColor="#1E88E5"
                       android:layout_marginTop="15dp"
                       android:textSize="13sp"
                       android:textStyle="bold" />


               </LinearLayout>

           </androidx.cardview.widget.CardView>

           <!-- BOOKING INFO -->
           <androidx.cardview.widget.CardView
               android:layout_marginTop="10dp"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               app:cardCornerRadius="12dp">



               <LinearLayout
                   android:padding="12dp"
                   android:orientation="vertical"
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content">

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:text="Nhận phòng"
                       />

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:id="@+id/txtCheckin"
                       android:textStyle="bold"

                       android:text="20/12/2026"/>
                   <View
                       android:layout_width="match_parent"
                       android:layout_height="1dp"
                       android:background="#EEEEEE"
                       android:layout_marginVertical="10dp"/>
                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:text="Trả phòng"
                       android:layout_marginTop="8dp"/>

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:id="@+id/txtCheckout"
                       android:textStyle="bold"
                       android:text="25/12/2026"/>

               </LinearLayout>
           </androidx.cardview.widget.CardView>


           <!-- CONTACT INFO -->
           <androidx.cardview.widget.CardView
               android:layout_marginTop="10dp"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               app:cardCornerRadius="12dp">

               <LinearLayout
                   android:padding="12dp"
                   android:orientation="vertical"
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content">


                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:text="Thông tin liên hệ"
                       android:textStyle="bold"/>

                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:gravity="center"
                       android:orientation="horizontal">
                       <TextView
                           android:layout_height="wrap_content"
                           android:layout_width="wrap_content"
                           android:layout_weight="1"
                           android:text="Họ và tên"/>
                       <TextView
                           android:textStyle="bold"
                           android:layout_height="wrap_content"
                           android:layout_width="wrap_content"
                           android:id="@+id/txtContactName"
                           android:text="Nguyen Van A"/>

                   </LinearLayout>

                   <View
                       android:layout_width="match_parent"
                       android:layout_height="1dp"
                       android:background="#EEEEEE"
                       android:layout_marginVertical="10dp"/>
                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:gravity="center"
                       android:orientation="horizontal">
                       <TextView
                           android:layout_height="wrap_content"
                           android:layout_width="wrap_content"
                           android:layout_weight="1"
                           android:text="Số điện thoại"/>
                       <TextView
                           android:layout_height="wrap_content"
                           android:layout_width="wrap_content"
                           android:id="@+id/txtPhone"
                           android:textStyle="bold"
                           android:text="098353553"/>
                   </LinearLayout>
                   <View
                       android:layout_width="match_parent"
                       android:layout_height="1dp"
                       android:background="#EEEEEE"
                       android:layout_marginVertical="10dp"/>

                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:gravity="center"
                       android:orientation="horizontal">
                       <TextView
                           android:layout_height="wrap_content"
                           android:layout_width="wrap_content"
                           android:layout_weight="1"
                           android:text="Email"/>
                       <TextView
                           android:layout_height="wrap_content"
                           android:layout_width="wrap_content"
                           android:id="@+id/txtEmail"
                           android:textStyle="bold"
                           android:text="nguyevana@mail.com"/>
                   </LinearLayout>



               </LinearLayout>
           </androidx.cardview.widget.CardView>


           <!-- PRICE DETAIL -->
           <androidx.cardview.widget.CardView
               android:layout_marginTop="10dp"
               android:layout_width="match_parent"
               android:layout_marginBottom="12dp"
               android:layout_height="wrap_content"
               app:cardCornerRadius="12dp">

               <LinearLayout
                   android:padding="12dp"
                   android:orientation="vertical"
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content">

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:text="Chi tiết giá"
                       android:textStyle="bold"/>

                   <!-- RecyclerView: BookedRoom list -->
                   <androidx.recyclerview.widget.RecyclerView
                       android:id="@+id/rvBookedRooms"
                       tools:listitem="@layout/booking_history_detail_item"
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:layout_marginTop="8dp"
                       android:nestedScrollingEnabled="false"/>



                   <!-- Total -->
                   <TextView
                       android:id="@+id/txtTotal"
                       android:layout_height="wrap_content"
                       android:layout_width="wrap_content"
                       android:layout_marginTop="8dp"
                       android:textStyle="bold"
                       android:textAppearance="?attr/textAppearanceTitleLarge"
                       android:text="Tổng: --"/>

               </LinearLayout>
           </androidx.cardview.widget.CardView>
           <androidx.cardview.widget.CardView
               android:id="@+id/qrCard"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:layout_marginTop="10dp"
               app:cardCornerRadius="12dp"
               android:layout_marginBottom="12dp"
               app:cardElevation="3dp">

               <LinearLayout
                   android:padding="12dp"
                   android:orientation="horizontal"
                   android:gravity="center_vertical"
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content">

                   <ImageView
                       android:id="@+id/imgQrSmall"
                       android:layout_width="80dp"
                       android:layout_height="80dp"
                       android:src="@drawable/ic_qr_placeholder"/>

                   <LinearLayout
                       android:layout_marginStart="12dp"
                       android:orientation="vertical"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content">

                       <TextView
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:text="Mã check-in"
                           android:textStyle="bold"
                           android:textSize="15sp"/>

                       <TextView
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:text="Nhấn để xem mã QR"
                           android:textColor="#666"
                           android:textSize="13sp"/>
                   </LinearLayout>

               </LinearLayout>

           </androidx.cardview.widget.CardView>
           <!-- CANCEL BOOKING CARD -->
           <androidx.cardview.widget.CardView
               android:id="@+id/cancelCard"
               android:layout_marginTop="10dp"
               android:layout_marginBottom="12dp"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               app:cardCornerRadius="12dp">

               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:orientation="vertical"
                   android:padding="12dp">

                   <TextView
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="Hủy đặt phòng"
                       android:textStyle="bold"
                       android:textColor="#D32F2F"/>

                   <TextView
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:layout_marginTop="8dp"
                       android:text="Lưu ý: Bạn chỉ có thể hủy đặt phòng khi đơn đang ở trạng thái chờ duyệt (Pending)."
                       android:textSize="13sp"
                       android:textColor="#666666"/>

                   <Button
                       android:id="@+id/btnCancelBooking"
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:layout_marginTop="12dp"
                       android:backgroundTint="#D32F2F"
                       android:text="Hủy đặt phòng"
                       android:textAllCaps="false"
                       app:cornerRadius="8dp"/>

               </LinearLayout>
           </androidx.cardview.widget.CardView>






       </LinearLayout>





    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>