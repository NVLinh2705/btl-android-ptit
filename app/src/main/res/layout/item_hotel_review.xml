<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/bg_section_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/imgReviewerAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/img" />

        <TextView
            android:id="@+id/txtReviewerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:textColor="#111111"
            android:textStyle="bold"
            android:text="my name"/>

        <TextView
            android:id="@+id/txtRatingNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_rating_pill"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:text="9.0"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtReviewDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#6D6D6D"
            android:textSize="12sp"
            android:text="1/1/2026"/>

        <TextView
            android:id="@+id/txtReviewRatingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="#0B4AA2"
            android:textSize="12sp"
            android:textStyle="bold"
            android:text="Rất tốt"/>

    </LinearLayout>

    <TextView
        android:id="@+id/txtReviewComment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#3D3D3D"
        android:textSize="13sp"
        android:text="nhận xét khách sạn"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRoomType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageView
                android:id="@+id/imgRoomType"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder_room" />

            <TextView
                android:id="@+id/txtRoomTypeName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:textColor="#111111"
                android:textSize="13sp"
                android:textStyle="bold"
                android:text="Tên loại phòng"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>

